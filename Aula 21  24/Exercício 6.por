programa {
  funcao inicio() {
    cadeia produto = "PS5"

    inteiro codigo = 223

    real preco = 3499.00

    logico disponivel = verdadeiro

    escreva("Produto: ", produto, "\n")
    escreva("Código do produto: ", codigo, "\n")
    escreva("Preço do produto: ", preco, "\n")
    escreva("Está disponivel?: ", disponivel, "\n")

  }
}
